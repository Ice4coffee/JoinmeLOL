  activeMcBot.once("login", () => {
    log("✅ Коннект. Ждем 2 сек для ввода пароля...");
    
    setTimeout(() => {
      activeMcBot.chat(`/l ${MC_PASSWORD}`);
      log("🔑 Пароль отправлен. Ждем 4 сек для перехода в лобби...");

      // СЛЕДУЮЩИЙ ШАГ: Переход в режим через 4 секунды после пароля
      setTimeout(() => {
        log(`📨 Команда: /play ${gameCode}`);
        activeMcBot.chat(`/play ${gameCode}`);

        // СЛЕДУЮЩИЙ ШАГ: JoinMe через 6 секунд после захода в режим
        setTimeout(() => {
          log("📢 Команда: /joinme");
          activeMcBot.chat("/joinme");
          ctx.reply(`✅ JoinMe отправлен в ${gameCode}! Пиши «лив» для выхода.`);
        }, 60000); // 6 секунд на загрузку мира игры

      }, 4000); // 4 секунды на прогрузку лобби после логина

    }, 2000);
  });
